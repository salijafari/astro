    "openai": "6.32.0",
    "prisma": "6.19.2",
    "sharp": "0.34.5",
    "sweph": "2.10.3-b-1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/luxon": "3.7.1",
