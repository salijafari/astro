generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                 @id @default(cuid())
  clerkId                 String?                @unique
  firebaseUid             String?                @unique @map("firebase_uid")
  email                   String                 @unique
  name                    String
  onboardingComplete      Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  subscriptionStatus      String                 @default("free")
  trialStartDate          DateTime?
  pushToken               String?
  notificationPreferences Boolean                @default(true)
  birthProfile            BirthProfile?
  compatibilityProfiles   CompatibilityProfile[]
  consentRecords          ConsentRecord[]
  conversations           Conversation[]
  dailyInsightCaches      DailyInsightCache[]
  dreamEntries            DreamEntry[]
  growthTimelineEntries   GrowthTimelineEntry[]
  journalEntries          JournalEntry[]
  pushNotificationLogs    PushNotificationLog[]
  tarotReadings           TarotReading[]
  experiments             UserExperiment[]
  winBackSchedule         WinBackSchedule?
  fcmTokens               FcmToken[]
  notificationPreference  NotificationPreference?
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  userId              String  @id @map("user_id")
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyHoroscope      Boolean @default(true) @map("daily_horoscope")
  preferredTimezone   String  @default("UTC") @map("preferred_timezone")
  preferredHour       Int     @default(9) @map("preferred_hour")

  @@map("notification_preferences")
}

model BirthProfile {
  id             String                 @id @default(cuid())
  userId         String                 @unique
  birthDate      DateTime
  birthTime      String?
  birthCity      String
  birthLat       Float
  birthLong      Float
  birthTimezone  String
  sunSign        String
  moonSign       String
  risingSign     String?
  natalChartJson Json
  interestTags   String[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLog       BirthProfileAuditLog[]
}

model BirthProfileAuditLog {
  id             String       @id @default(cuid())
  birthProfileId String
  changedAt      DateTime     @default(now())
  changedBy      String
  previousData   Json
  birthProfile   BirthProfile @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  content    String
  moodTag    String?
  promptUsed String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CompatibilityProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  relationship   String
  birthDate      DateTime
  birthTime      String?
  birthCity      String
  birthLat       Float
  birthLong      Float
  birthTimezone  String
  natalChartJson Json
  reportCache    Json?
  synastryScore  Int?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  agreedAt    DateTime @default(now())
  ipAddress   String?
  version     String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyInsightCache {
  id          String   @id @default(cuid())
  userId      String
  date        String
  content     Json
  generatedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model DreamEntry {
  id             String   @id @default(cuid())
  userId         String
  dreamText      String
  interpretation Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TarotReading {
  id         String   @id @default(cuid())
  userId     String
  spreadType String
  intention  String?
  cardsJson  Json
  summary    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GrowthTimelineEntry {
  id        String   @id @default(cuid())
  userId    String
  entryType String
  theme     String?
  summary   String?
  sourceId  String?
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model UserExperiment {
  id             String   @id @default(cuid())
  userId         String
  experimentName String
  variant        String
  assignedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentName])
}

model PushNotificationLog {
  id           String    @id @default(cuid())
  userId       String?
  kind         String
  body         String
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id])
}

model WinBackSchedule {
  id        String   @id @default(cuid())
  userId    String   @unique
  runAt     DateTime
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
