generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// At least one of clerkId or firebaseUid must be set (enforced in DB via CHECK migration).
model User {
  id                      String                 @id @default(cuid())
  clerkId                 String?                @unique
  firebaseUid             String?                @unique @map("firebase_uid")
  email                   String                 @unique
  name                    String
  onboardingComplete      Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  subscriptionStatus      String                 @default("free")
  trialStartDate          DateTime?
  pushToken               String?
  notificationPreferences Boolean                @default(true)
  birthProfile            BirthProfile?
  compatibilityProfiles   CompatibilityProfile[]
  peopleProfiles         PeopleProfile[]
  dailyHoroscopes        DailyHoroscope[]
  compatibilityReports   CompatibilityReport[]
  chatSessions           ChatSession[]
  coffeeReadings         CoffeeReading[]
  growthWeeklyDigests    GrowthWeeklyDigest[]
  lifeChallengeReports   LifeChallengeReport[]
  astroEvents            AstroEvent[]
  futureSeerReports     FutureSeerReport[]
  consentRecords          ConsentRecord[]
  conversations           Conversation[]
  dailyInsightCaches      DailyInsightCache[]
  dreamEntries            DreamEntry[]
  growthTimelineEntries   GrowthTimelineEntry[]
  journalEntries          JournalEntry[]
  pushNotificationLogs    PushNotificationLog[]
  tarotReadings           TarotReading[]
  experiments             UserExperiment[]
  winBackSchedule         WinBackSchedule?
  fcmTokens               FcmToken[]
  notificationPreference  NotificationPreference?
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  userId              String  @id @map("user_id")
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyHoroscope      Boolean @default(true) @map("daily_horoscope")
  preferredTimezone   String  @default("UTC") @map("preferred_timezone")
  preferredHour       Int     @default(9) @map("preferred_hour")

  @@map("notification_preferences")
}

model BirthProfile {
  id             String                 @id @default(cuid())
  userId         String                 @unique
  birthDate      DateTime
  birthTime      String?
  birthCity      String
  birthLat       Float
  birthLong      Float
  birthTimezone  String
  sunSign        String
  moonSign       String
  risingSign     String?
  natalChartJson Json
  interestTags   String[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLog       BirthProfileAuditLog[]
}

model BirthProfileAuditLog {
  id             String       @id @default(cuid())
  birthProfileId String
  changedAt      DateTime     @default(now())
  changedBy      String
  previousData   Json
  birthProfile   BirthProfile @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  content    String   @db.Text
  moodTag    String?
  promptUsed String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CompatibilityProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  relationship   String
  birthDate      DateTime
  birthTime      String?
  birthCity      String
  birthLat       Float
  birthLong      Float
  birthTimezone  String
  natalChartJson Json
  reportCache    Json?
  synastryScore  Int?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  agreedAt    DateTime @default(now())
  ipAddress   String?
  version     String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyInsightCache {
  id          String   @id @default(cuid())
  userId      String
  date        String
  content     Json
  generatedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model DreamEntry {
  id             String   @id @default(cuid())
  userId         String
  dreamText      String   @db.Text
  interpretation Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TarotReading {
  id         String   @id @default(cuid())
  userId     String
  spreadType String
  intention  String?  @db.Text
  cardsJson  Json
  summary    String   @db.Text
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GrowthTimelineEntry {
  id        String   @id @default(cuid())
  userId    String
  entryType String
  theme     String?
  summary   String?  @db.Text
  sourceId  String?
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model UserExperiment {
  id             String   @id @default(cuid())
  userId         String
  experimentName String
  variant        String
  assignedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentName])
}

model PushNotificationLog {
  id           String    @id @default(cuid())
  userId       String?
  kind         String
  body         String
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WinBackSchedule {
  id        String   @id @default(cuid())
  userId    String   @unique
  runAt     DateTime
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Dashboard feature tables (v2)
model PeopleProfile {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  relationshipType  String
  birthDate         DateTime
  birthTime         String?
  birthPlace        String?
  birthLat          Float?
  birthLng          Float?
  birthTimezone     String?
  hasFullData       Boolean  @default(false)
  natalChartJson    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  compatibilityReports CompatibilityReport[]

  @@index([userId, createdAt])
}

model DailyHoroscope {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String
  title       String
  body        String   @db.Text
  moodLabel   String
  affirmation String?
  focusArea   String?
  transitJson Json
  generatedAt DateTime @default(now())

  @@unique([userId, date])
}

model CompatibilityReport {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personProfileId    String
  personProfile      PeopleProfile @relation(fields: [personProfileId], references: [id], onDelete: Cascade)
  overallScore       Int
  emotionalScore     Int
  communicationScore Int
  attractionScore    Int
  longTermScore      Int
  conflictScore      Int
  narrativeSummary   String       @db.Text
  tips               Json
  synastryScoringJson Json
  isFullReport       Boolean      @default(false)
  createdAt          DateTime     @default(now())

  @@index([userId, createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicTag  String
  title     String?
  messages  ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String      @db.Text
  followUps Json?
  modelUsed String?
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model CoffeeReading {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl          String
  visionObservations Json
  symbolicMappings  Json
  interpretation    String   @db.Text
  followUpMessages  Json?
  imageQualityFlag  Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model GrowthWeeklyDigest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart String
  summary   String   @db.Text
  themes    Json
  createdAt DateTime @default(now())

  @@unique([userId, weekStart])
}

model LifeChallengeReport {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeClusters Json
  interpretation    String   @db.Text
  hiddenStrengths   Json
  practicePrompts   Json
  transitContext    Json?
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model AstroEvent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType       String
  title           String
  eventDate       DateTime
  significance    Int
  category        String
  whyItMatters    String   @db.Text
  suggestedAction String
  windowStart     DateTime
  windowEnd       DateTime
  notified        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId, eventDate])
}

model FutureSeerReport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain         String
  timeWindow     String
  upcomingThemes Json
  transitSupport Json
  timingWindows  Json
  risks          Json
  opportunities  Json
  actionableNow  String   @db.Text
  confidenceNote String
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}
