{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "secretFiles": {
        "GOOGLE_SERVICE_INFO_PLIST": "./config/GoogleService-Info.plist"
      }
    },
    "preview": {
      "distribution": "internal",
      "secretFiles": {
        "GOOGLE_SERVICE_INFO_PLIST": "./config/GoogleService-Info.plist"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "secretFiles": {
        "GOOGLE_SERVICE_INFO_PLIST": "./config/GoogleService-Info.plist"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
