{
  "expo": {
    "name": "Akhtar Horoscope",
    "slug": "astro-coach-app",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "astrocoach",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "googleServicesFile": "./config/GoogleService-Info.plist",
      "supportsTablet": true,
      "bundleIdentifier": "today.akhtar.astrocoach",
      "appleTeamId": "7VYFF7H2RJ",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./config/google-services.json",
      "package": "today.akhtar.astrocoach",
      "edgeToEdgeEnabled": true,
      "allowBackup": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Akhtar Horoscope",
      "shortName": "Akhtar Horoscope",
      "themeColor": "#0f172a",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      "./plugins/withFirebaseModularHeaders",
      [
        "@react-native-firebase/app",
        {
          "ios": {
            "modular_headers": true
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Akhtar needs access to your photos to read your coffee cup.",
          "cameraPermission": "Akhtar needs access to your camera to read your coffee cup."
        }
      ],
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f172a"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          },
          "android": {
            "minSdkVersion": 26,
            "enableProguardInReleaseBuilds": false,
            "resizeableActivity": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-tracking-transparency",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-font",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.102932271918-6hqntpdfms9i6fguo6g50e0r3afe4v5h"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "akhtar-m3",
          "uploadSourceMaps": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d059dac0-8c92-4013-b3bc-20f85be69641"
      }
    }
  }
}
