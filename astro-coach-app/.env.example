# Copy to .env.local for local dev. For Railway PWA, set the same EXPO_PUBLIC_* keys in the dashboard (never commit secrets).

EXPO_PUBLIC_API_URL=
# Production site origin (e.g. https://app.yourdomain.com) — used for Stripe return URLs on web.
# For Google sign-in on web: Firebase Console → Authentication → Settings → Authorized domains
# must include that same host (and localhost for dev). If sign-in stalls on
# https://<project>.firebaseapp.com/__/auth/handler, the return URL host is usually missing there.

EXPO_PUBLIC_APP_URL=

# Firebase (Web SDK — safe to expose as EXPO_PUBLIC_)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Web push (FCM) — optional
EXPO_PUBLIC_FIREBASE_VAPID_KEY=

# RevenueCat public SDK keys (mobile only; omitted on web paywall)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Stripe web subscription — display price shown on paywall screen
EXPO_PUBLIC_SUBSCRIPTION_PRICE_DISPLAY=$9.99/month

# Optional analytics
EXPO_PUBLIC_MIXPANEL_TOKEN=

# Google Places (city search in chat onboarding)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google Sign-In (native config uses this as webClientId)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: full URL for sign-in hero image on web (defaults to /assets/hero.png from public/)
EXPO_PUBLIC_SIGN_IN_HERO_URL=
